---
import type { ResearchArea } from "../data/site";
import { publications, type Publication, type PublicationLink } from "../data/publications";
import { projects, type Project } from "../data/projects";
import { shortVenue } from "../data/derived";

interface Props {
  areas: ResearchArea[];
}

const { areas } = Astro.props;
const publicationById = new Map(publications.map((publication) => [publication.id, publication]));
const projectById = new Map(projects.map((project) => [project.id, project]));
const linkOrder: PublicationLink["label"][] = ["Paper", "Proceedings", "DOI", "Preprint", "Code"];
const primaryLink = (links: PublicationLink[]) => {
  for (const label of linkOrder) {
    const found = links.find((link) => link.label === label);
    if (found) return found;
  }
  return links[0];
};
const relatedPublications = (ids: string[] = []): Publication[] =>
  ids.map((id) => publicationById.get(id)).filter((publication): publication is Publication => Boolean(publication));
const relatedProjects = (ids: string[] = []): Project[] =>
  ids.map((id) => projectById.get(id)).filter((project): project is Project => Boolean(project));
---

<div class="rec-grid rec-grid-fit">
  {areas.map((area) => (
    <article class="rec-card">
      <h2>{area.title}</h2>
      <p>{area.text}</p>
      <ul class="rec-tags">
        {area.methods.map((method) => <li>{method}</li>)}
      </ul>
      {
        area.relatedPublicationIds?.length || area.relatedProjectIds?.length ? (
          <div class="rec-related">
            <p class="rec-kicker">Related outputs</p>
            <ul>
              {relatedPublications(area.relatedPublicationIds).map((publication) => {
                const link = primaryLink(publication.links);
                return (
                  <li>
                    <span>{shortVenue(publication)}</span>
                    {link ? (
                      <a href={link.href} target="_blank" rel="noopener">{publication.title}</a>
                    ) : (
                      <span>{publication.title}</span>
                    )}
                  </li>
                );
              })}
              {relatedProjects(area.relatedProjectIds).map((project) => (
                <li>
                  <span>Software</span>
                  <a href={project.href} target="_blank" rel="noopener">{project.name}</a>
                </li>
              ))}
            </ul>
          </div>
        ) : null
      }
    </article>
  ))}
</div>
