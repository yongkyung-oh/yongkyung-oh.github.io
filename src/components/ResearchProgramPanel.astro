---
import { profile, siteContent } from "../data/site";
---

<aside class="rec-profile-panel" aria-label="Current research profile">
  <div class="rec-portrait-wrap">
    <picture>
      <source srcset={profile.portrait} type="image/webp" />
      <img
        src={profile.portraitFallback}
        alt="YongKyung Oh presenting at a podium"
        width={profile.portraitWidth}
        height={profile.portraitHeight}
        fetchpriority="high"
        decoding="async"
      />
    </picture>
  </div>
  <div class="rec-profile-copy">
    <p class="rec-kicker">{profile.group}</p>
    <strong>{profile.role}</strong>
    <span>{profile.affiliation}</span>
  </div>
  <dl class="rec-program-list">
    {siteContent.currentProgram.map((item) => (
      <div>
        <dt>{item.label}</dt>
        <dd>
          <strong>{item.value}</strong>
          <span>{item.detail}</span>
        </dd>
      </div>
    ))}
  </dl>
</aside>
