---
import type { Recognition } from "../data/derived";

interface Props {
  recognitions: Recognition[];
}

const { recognitions } = Astro.props;
---

<div class="rec-grid rec-grid-fit">
  {recognitions.map((recognition) => (
    <article class="rec-card">
      <p class="rec-kicker">{recognition.venue}</p>
      <h2><a href={recognition.href} target="_blank" rel="noopener">{recognition.award}</a></h2>
      <p>{recognition.title}</p>
    </article>
  ))}
</div>
