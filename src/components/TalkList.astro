---
import type { Talk } from "../data/talks";

interface Props {
  talks: Talk[];
}

const { talks } = Astro.props;
---

<ol class="rec-record-list">
  {talks.map((talk) => (
    <li>
      <div class="rec-record-meta">
        <span>{talk.date}</span>
        <span>{talk.type}</span>
        {talk.organization && <span>{talk.organization}</span>}
      </div>
      <article class="rec-record-body">
        <h2>{talk.title}</h2>
        <p>{talk.venue}</p>
        {talk.links?.length ? (
          <div class="rec-record-links">
            {talk.links.map((link) => (
              <a href={link.href} target="_blank" rel="noopener">{link.label}</a>
            ))}
          </div>
        ) : null}
      </article>
    </li>
  ))}
</ol>
