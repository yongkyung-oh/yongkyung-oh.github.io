---
import type { EducationRecord } from "../data/education";

interface Props {
  records: EducationRecord[];
}

const { records } = Astro.props;
---

<ol class="rec-record-list">
  {records.map((record) => (
    <li>
      <div class="rec-record-meta">
        <span>{record.period}</span>
        {record.field && <span>{record.field}</span>}
      </div>
      <article class="rec-record-body">
        <h2>{record.degree}</h2>
        <p>{record.institution}</p>
        {record.detail && <p>{record.detail}</p>}
      </article>
    </li>
  ))}
</ol>
