---
import type { Patent } from "../data/patents";

interface Props {
  patents: Patent[];
}

const { patents } = Astro.props;
---

<ol class="rec-compact-list">
  {patents.map((patent) => (
    <li>
      <div class="rec-record-meta">
        <span>{patent.year}</span>
        <span>{patent.jurisdiction}</span>
        <span>{patent.status}</span>
      </div>
      <article class="rec-record-body">
        <h2>{patent.title}</h2>
        <p>{patent.inventors}</p>
      </article>
    </li>
  ))}
</ol>
