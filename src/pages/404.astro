---
import SiteLayout from "../layouts/SiteLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import { routePath } from "../data/routes";
---

<SiteLayout title="Page not found" description="This page does not exist." current="Home">
  <PageHeader
    eyebrow="404"
    title="Page not found."
    lead="The page you were looking for is not here. Use the links below to get back on track."
  />
  <section class="rec-section" aria-label="Recovery links">
    <div class="rec-actions">
      <a class="rec-button primary" href={routePath()}>Home</a>
      <a class="rec-button" href={routePath("publications")}>Publications</a>
      <a class="rec-button" href={routePath("research")}>Research</a>
    </div>
  </section>
</SiteLayout>
