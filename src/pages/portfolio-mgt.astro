---
import SiteLayout from "../layouts/SiteLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import PortfolioRecordList from "../components/PortfolioRecordList.astro";
import { portfolioRecords } from "../data/portfolioRecords";

const records = portfolioRecords.filter((record) => record.track === "industry-consulting");
---

<SiteLayout title="Consulting Works" description="Consulting records listed when verified for publication." current="Projects">
  <PageHeader
    eyebrow="Archive"
    title="Management and consulting works."
    lead="Consulting entries are not listed here unless they are verified for publication."
  />

  <section class="rec-section" aria-labelledby="consulting-title">
    <div class="rec-section-head">
      <p class="rec-kicker">Consulting</p>
      <h2 id="consulting-title">Strategy and management project summaries.</h2>
    </div>
    <PortfolioRecordList
      records={records}
      emptyMessage="No consulting records are listed on the public site yet."
    />
  </section>
</SiteLayout>
