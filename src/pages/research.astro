---
import SiteLayout from "../layouts/SiteLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import InfoCardList from "../components/InfoCardList.astro";
import ResearchAreaList from "../components/ResearchAreaList.astro";
import { siteContent } from "../data/site";
import { currentWork } from "../data/research";
---

<SiteLayout title="Research" description={siteContent.mission} current="Research">
  <PageHeader
    eyebrow="Research"
    title="Reliable learning from irregular health data."
    lead={siteContent.mission}
  />

  <section class="rec-section" aria-labelledby="focus-title">
    <div class="rec-section-head">
      <p class="rec-kicker">Program</p>
      <h2 id="focus-title">Three lines, one reliability problem.</h2>
    </div>
    <ResearchAreaList areas={siteContent.focusAreas} />
  </section>

  <section class="rec-section" aria-labelledby="current-title">
    <div class="rec-section-head">
      <p class="rec-kicker">Current Work</p>
      <h2 id="current-title">From method development to health-data evaluation.</h2>
    </div>
    <InfoCardList items={currentWork} />
  </section>
</SiteLayout>
