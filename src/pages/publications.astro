---
import SiteLayout from "../layouts/SiteLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import PublicationList from "../components/PublicationList.astro";
import { publications } from "../data/publications";
import type { Publication, PublicationLink } from "../data/publications";
import { stats } from "../data/derived";

const articleLinkLabels: PublicationLink["label"][] = ["DOI", "Paper", "Proceedings", "Preprint"];
const articleLinks = (publication: Publication) =>
  publication.links.filter((link) => articleLinkLabels.includes(link.label));
const publicationGraph = {
  "@context": "https://schema.org",
  "@graph": publications.map((publication) => {
    const links = articleLinks(publication);
    const primaryLink = links[0] ?? publication.links[0];
    return {
      "@type": "ScholarlyArticle",
      "@id": primaryLink?.href,
      headline: publication.apaTitle ?? publication.title,
      name: publication.title,
      author: publication.apaAuthors ?? publication.authors,
      datePublished: String(publication.year),
      publicationYear: publication.year,
      isPartOf: {
        "@type": publication.kind === "journal" ? "Periodical" : "PublicationIssue",
        name: publication.venue
      },
      url: primaryLink?.href,
      sameAs: links.map((link) => link.href),
      about: publication.tags,
      description: publication.summary
    };
  })
};
---

<SiteLayout
  title="Publications"
  description="Selected publications with APA-style author metadata, venues, years, and paper or code links."
  current="Publications"
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(publicationGraph)} />

  <PageHeader
    eyebrow="Publications"
    title="Selected Publications"
    lead="A focused list of recent and representative papers, listed with APA-style author metadata, venues, years, and available paper or code links."
  />

  <section class="rec-section" aria-label="Publication totals">
    <div class="rec-metrics">
      <div class="rec-metric">
        <strong>{stats.totalPublications}</strong>
        <span>Curated Papers</span>
      </div>
      <div class="rec-metric">
        <strong>{stats.journalCount}</strong>
        <span>Journal</span>
      </div>
      <div class="rec-metric">
        <strong>{stats.conferenceCount}</strong>
        <span>Conference</span>
      </div>
      <div class="rec-metric">
        <strong>{stats.featuredCount}</strong>
        <span>Featured</span>
      </div>
    </div>
  </section>

  <section class="rec-section" aria-labelledby="record-title">
    <div class="rec-section-head">
      <p class="rec-kicker">Record</p>
      <h2 id="record-title">Papers, venues, and links in one place.</h2>
    </div>
    <div class="rec-filterbar" aria-label="Publication filters">
      <button type="button" data-pub-filter="all" aria-pressed="true">All</button>
      <button type="button" data-pub-filter="journal" aria-pressed="false">Journal</button>
      <button type="button" data-pub-filter="conference" aria-pressed="false">Conference</button>
      <button type="button" data-pub-filter="accepted" aria-pressed="false">Accepted</button>
      <button type="button" data-pub-filter="featured" aria-pressed="false">Selected</button>
    </div>
    <p class="rec-filtercount" aria-live="polite"></p>
    <PublicationList publications={publications} />
  </section>
  <script>
    const buttons = Array.from(document.querySelectorAll<HTMLButtonElement>("[data-pub-filter]"));
    const rows = Array.from(document.querySelectorAll<HTMLElement>(".rec-publist > li"));
    const count = document.querySelector(".rec-filtercount");
    const validFilters = new Set(["all", "journal", "conference", "accepted", "featured"]);
    const visibleFor = (row: HTMLElement, filter: string) => {
      if (filter === "all") return true;
      if (filter === "accepted") return ["accepted", "in_press"].includes(row.dataset.pubStatus || "");
      if (filter === "featured") return row.dataset.pubFeatured === "true";
      return row.dataset.pubKind === filter;
    };
    const applyFilter = (filter: string) => {
      const safeFilter = validFilters.has(filter) ? filter : "all";
      let visible = 0;
      rows.forEach((row) => {
        const show = visibleFor(row, safeFilter);
        row.hidden = !show;
        if (show) visible += 1;
      });
      buttons.forEach((button) => {
        button.setAttribute("aria-pressed", String(button.dataset.pubFilter === safeFilter));
      });
      if (count) count.textContent = `${visible} papers shown`;
      const url = new URL(window.location.href);
      if (safeFilter === "all") url.searchParams.delete("type");
      else url.searchParams.set("type", safeFilter);
      window.history.replaceState(null, "", url);
    };
    buttons.forEach((button) => {
      button.addEventListener("click", () => applyFilter(button.dataset.pubFilter || "all"));
    });
    applyFilter(new URLSearchParams(window.location.search).get("type") || "all");
  </script>
</SiteLayout>
