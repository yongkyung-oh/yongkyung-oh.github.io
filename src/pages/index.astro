---
import SiteLayout from "../layouts/SiteLayout.astro";
import ResearchProgramPanel from "../components/ResearchProgramPanel.astro";
import PublicationList from "../components/PublicationList.astro";
import NewsList from "../components/NewsList.astro";
import ResearchAreaList from "../components/ResearchAreaList.astro";
import { profile, siteContent } from "../data/site";
import { news } from "../data/news";
import { recentPublications } from "../data/derived";
import { routePath } from "../data/routes";

const emailDisplay = profile.email.replace(/^mailto:/, "");
---

<SiteLayout title="Home" description={siteContent.tagline} current="Home">
  <section class="rec-hero" aria-labelledby="home-title">
    <div>
      <p class="rec-kicker">{siteContent.homeKicker}</p>
      <h1 id="home-title">{profile.name}</h1>
      <p class="rec-subtitle">{siteContent.tagline}</p>
      <p class="rec-lead">{siteContent.statement}</p>
      <div class="rec-actions">
        <a class="rec-button primary" href={routePath("publications")}>Publications</a>
        <a class="rec-button" href={routePath("research")}>Research</a>
        <a class="rec-button" href={`mailto:${emailDisplay}`}>{emailDisplay}</a>
      </div>
    </div>
    <ResearchProgramPanel />
  </section>

  <section class="rec-section" aria-labelledby="selected-title">
    <div class="rec-section-head">
      <p class="rec-kicker">Publications</p>
      <h2 id="selected-title">Recent and representative papers.</h2>
    </div>
    <PublicationList publications={recentPublications} />
    <div class="rec-actions">
      <a class="rec-button" href={routePath("publications")}>View Publications</a>
      <a class="rec-button" href={routePath("projects")}>View Projects</a>
    </div>
  </section>

  <section class="rec-section" aria-labelledby="route-title">
    <div class="rec-section-head">
      <p class="rec-kicker">Research</p>
      <h2 id="route-title">Reliable learning under missingness, shift, and irregular sampling.</h2>
    </div>
    <ResearchAreaList areas={siteContent.focusAreas} />
  </section>

  <section class="rec-section" aria-labelledby="news-title">
    <div class="rec-section-head">
      <p class="rec-kicker">News</p>
      <h2 id="news-title">Recent updates.</h2>
    </div>
    <NewsList items={news} />
  </section>
</SiteLayout>
