---
import SiteLayout from "../layouts/SiteLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import ProjectList from "../components/ProjectList.astro";
import { projects } from "../data/projects";
---

<SiteLayout
  title="Software"
  description="Research software and reusable artifacts connected to published work."
  current="Projects"
>
  <PageHeader
    eyebrow="Software"
    title="Reusable research artifacts."
    lead="Repositories and reusable code that support methods, experiments, and publication workflows."
  />

  <section class="rec-section" aria-labelledby="software-title">
    <div class="rec-section-head">
      <p class="rec-kicker">Artifacts</p>
      <h2 id="software-title">Code as part of the research record.</h2>
    </div>
    <ProjectList projects={projects} />
  </section>
</SiteLayout>
