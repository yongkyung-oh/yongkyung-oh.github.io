---
import SiteLayout from "../../layouts/SiteLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import PortfolioRecordList from "../../components/PortfolioRecordList.astro";
import { portfolioRecords } from "../../data/portfolioRecords";

export function getStaticPaths() {
  return portfolioRecords
    .filter((record) => record.track === "research-development" && record.legacySlug)
    .map((record) => ({
      params: { slug: record.legacySlug },
      props: { record }
    }));
}

const { record } = Astro.props;
---

<SiteLayout title={record.title} description={record.summary} current="Projects">
  <PageHeader
    eyebrow="Development Work"
    title={record.title}
    lead={record.summary}
  />

  <section class="rec-section" aria-labelledby="project-title">
    <div class="rec-section-head">
      <p class="rec-kicker">{record.organization}</p>
      <h2 id="project-title">Public project summary.</h2>
    </div>
    <PortfolioRecordList records={[record]} />
  </section>
</SiteLayout>
