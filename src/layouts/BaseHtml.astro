---
// Production HTML shell for the routed site.
// - Device-preference light/dark (saved → device → light), no-flash inline script.
// - Light / Dark toggle support.
// - Canonical + Open Graph + Twitter meta (indexable by default).
import { profile } from "../data/site";

interface Props {
  title: string;
  description?: string;
  image?: string;
  themeColor?: string;
  themeColorDark?: string;
  robots?: string;
}
const {
  title,
  description = "",
  image = profile.ogImage,
  themeColor = "#f3f0ea",
  themeColorDark = "#101216",
  robots = "index, follow"
} = Astro.props;

const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : Astro.url.pathname;
const ogImage = Astro.site ? new URL(image, Astro.site).href : image;
const siteName = `${profile.name} — ${profile.role}`;
const isHome = Astro.url.pathname === "/" || Astro.url.pathname === "";

// Structured data (JSON-LD). Honest, traceable identity only — no fabricated metrics.
const personLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: profile.name,
  jobTitle: profile.role,
  affiliation: { "@type": "Organization", name: profile.affiliation },
  email: profile.email.replace(/^mailto:/, ""),
  image: ogImage,
  url: Astro.site ? Astro.site.href : canonical,
  sameAs: [profile.scholarUrl, profile.githubUrl, profile.linkedinUrl].filter(Boolean)
};
const websiteLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: siteName,
  url: Astro.site ? Astro.site.href : canonical,
  author: { "@type": "Person", name: profile.name }
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <meta name="theme-color" content={themeColor} data-light={themeColor} data-dark={themeColorDark} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="canonical" href={canonical} />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    {robots && <meta name="robots" content={robots} />}

    <meta property="og:type" content={isHome ? "website" : "article"} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="900" />
    <meta property="og:image:alt" content={`${profile.name}, ${profile.role}`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={`${profile.name}, ${profile.role}`} />

    <script is:inline type="application/ld+json" set:html={JSON.stringify(personLd)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(websiteLd)} />

    <script is:inline>
      (() => {
        const saved = localStorage.getItem("portfolio-theme");
        const hasSaved = saved === "light" || saved === "dark";
        const prefersDark =
          window.matchMedia && window.matchMedia("(prefers-color-scheme: dark)").matches;
        const theme = hasSaved ? saved : prefersDark ? "dark" : "light";
        document.documentElement.dataset.theme = theme;
        document.documentElement.dataset.themeMode = hasSaved ? "manual" : "device";
        document.documentElement.style.colorScheme = theme;
        const meta = document.querySelector('meta[name="theme-color"]');
        if (meta) {
          meta.setAttribute(
            "content",
            theme === "dark" ? meta.dataset.dark || "#101216" : meta.dataset.light || "#f3f0ea"
          );
        }
      })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <slot name="head" />
  </head>
  <body>
    <slot />
    <script is:inline>
      (() => {
        const root = document.documentElement;
        const buttons = Array.from(document.querySelectorAll("[data-theme-mode-choice]"));
        const meta = document.querySelector('meta[name="theme-color"]');
        const deviceTheme = () =>
          window.matchMedia && window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
        const setMeta = (theme) => {
          if (meta) {
            meta.setAttribute(
              "content",
              theme === "dark" ? meta.dataset.dark || "#101216" : meta.dataset.light || "#f3f0ea"
            );
          }
        };
        const setPressed = (theme) => {
          buttons.forEach((b) =>
            b.setAttribute("aria-pressed", String(b.dataset.themeModeChoice === theme))
          );
        };
        const apply = (themeChoice) => {
          if (themeChoice !== "light" && themeChoice !== "dark") return;
          localStorage.setItem("portfolio-theme", themeChoice);
          const theme = themeChoice;
          root.dataset.theme = theme;
          root.dataset.themeMode = "manual";
          root.style.colorScheme = theme;
          setMeta(theme);
          setPressed(theme);
        };
        const sync = () => {
          const saved = localStorage.getItem("portfolio-theme");
          const theme = saved === "light" || saved === "dark" ? saved : deviceTheme();
          root.dataset.theme = theme;
          root.dataset.themeMode = saved === "light" || saved === "dark" ? "manual" : "device";
          root.style.colorScheme = theme;
          setMeta(theme);
          setPressed(theme);
        };
        buttons.forEach((b) =>
          b.addEventListener("click", () => apply(b.dataset.themeModeChoice || "light"))
        );
        sync();
        if (window.matchMedia) {
          window.matchMedia("(prefers-color-scheme: dark)").addEventListener("change", () => {
            const saved = localStorage.getItem("portfolio-theme");
            if (saved !== "light" && saved !== "dark") sync();
          });
        }
      })();
    </script>
  </body>
</html>

<style is:global>
  * {
    box-sizing: border-box;
  }
  html {
    -webkit-text-size-adjust: 100%;
  }
  body {
    margin: 0;
  }
  img,
  svg {
    display: block;
    max-width: 100%;
  }
  a {
    color: inherit;
  }
  @media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
      animation-duration: 0.001ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.001ms !important;
      scroll-behavior: auto !important;
    }
  }
</style>
